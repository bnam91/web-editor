        { "id": "row-padx-number", "type": "number", "label": "좌우 패딩", "event": "change", "writes": "applyPadX", "silentFailRisk": "none", "note": "L199. 슬라이더 쌍." },
        { "id": "row-child-h-slider", "type": "range", "label": "높이(자식 일괄)", "event": "input", "writes": "childBlocks[].style.minHeight", "silentFailRisk": "low", "note": "L212-214. hasChildren일 때만 비-옵셔널 addEventListener. hasChildren 가드로 보호됨." },
