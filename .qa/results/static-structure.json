        { "id": "ss-gap-slider", "type": "range", "label": "간격(gap)", "event": "input(bindSlider)", "writes": "ss.style.gap + ss.dataset.gap", "silentFailRisk": "none", "note": "L501-503. _setGap 정상." },
        { "id": "ss-gap-num", "type": "number", "label": "간격(gap)", "event": "input/change(bindSlider)", "writes": "ss.style.gap + dataset.gap", "silentFailRisk": "none", "note": "슬라이더 쌍." },
        { "id": "ss-rotate-deg", "type": "number", "label": "각도", "event": "input", "writes": "ss.dataset.rotateDeg + style.transform", "silentFailRisk": "low", "note": "L506-509. pushHistory 누락 (autoSave만)." },
        { "id": "ss-rotate-90", "type": "button", "label": "90° 회전", "event": "click", "writes": "ss.dataset.rotateDeg + input value + transform", "silentFailRisk": "low", "note": "L510-517. pushHistory 누락." },
        { "id": "ss-flip-h", "type": "button", "label": "좌우 반전", "event": "click", "writes": "ss.dataset.flipH + transform", "silentFailRisk": "low", "note": "L518-522. pushHistory 누락." },
        { "id": "ss-flip-v", "type": "button", "label": "상하 반전", "event": "click", "writes": "ss.dataset.flipV + transform", "silentFailRisk": "low", "note": "L523-527. pushHistory 누락." },
        { "id": "ss-bg-img-btn", "type": "button", "label": "이미지 선택", "event": "click", "writes": "file input 트리거", "silentFailRisk": "med", "note": "L533/538. bgImgBtn.addEventListener 비-옵셔널 → bgImgBtn null이면 throw. 다른 버튼들과 달리 항상 존재(조건 없는 섹션)라 실제론 OK이나 ?. 없음=방어 불일치." },
        { "id": "ss-bg-img-input", "type": "file", "label": "(숨김 파일입력)", "event": "change", "writes": "ss.style.backgroundImage + dataset.bgImg, 동적 버튼 생성", "silentFailRisk": "low", "note": "L539-570. 정상. pushHistory/autoSave 호출됨." },
        { "id": "ss-bg-pos-btn", "type": "button", "label": "위치 편집", "event": "click", "writes": "window.enterBgPosDragMode(ss)", "silentFailRisk": "low", "note": "L584. hasBgImg일 때만 정적 존재. 동적 생성도 있음." },
        { "id": "ss-bg-img-clear", "type": "button", "label": "이미지 제거", "event": "click", "writes": "removeBgImg → style/dataset 정리", "silentFailRisk": "none", "note": "L583." },
        { "id": "ss-bg (color field)", "type": "color+alpha+gradient", "label": "배경색", "event": "wireColorField", "writes": "ss.style.backgroundColor/background + dataset.bg", "silentFailRisk": "none", "note": "L587-605. solid/gradient 모두 처리." },
        { "id": "ss-border-w-slider", "type": "range", "label": "두께", "event": "input(bindSlider)", "writes": "applyBorder → ss.style.border + dataset.borderWidth", "silentFailRisk": "none", "note": "L608-619." },
        { "id": "ss-border-w-num", "type": "number", "label": "두께", "event": "input/change(bindSlider)", "writes": "applyBorder", "silentFailRisk": "none", "note": "슬라이더 쌍." },
        { "id": "ss-border-style", "type": "select", "label": "스타일", "event": "change", "writes": "applyBorder → dataset.borderStyle + style.border", "silentFailRisk": "none", "note": "L620." },
        { "id": "ss-border (color field)", "type": "color+alpha", "label": "색상", "event": "wireColorField", "writes": "_borderColor + applyBorder → dataset.borderColor", "silentFailRisk": "none", "note": "L621-625." },
        { "id": "ss-radius-slider", "type": "range", "label": "코너", "event": "input(bindSlider)", "writes": "ss.dataset.radius + style.borderRadius", "silentFailRisk": "none", "note": "L628-631." },
        { "id": "ss-radius-num", "type": "number", "label": "코너", "event": "input/change(bindSlider)", "writes": "ss.style.borderRadius", "silentFailRisk": "none", "note": "슬라이더 쌍." },
        { "id": "ss-width-slider", "type": "range", "label": "너비", "event": "input(bindSlider)", "writes": "applyWidth → ss.dataset.width + style.width + 자식 비례 스케일", "silentFailRisk": "none", "note": "L673-717." },
        { "id": "ss-width-num", "type": "number", "label": "너비", "event": "input/change(bindSlider)", "writes": "applyWidth", "silentFailRisk": "none", "note": "슬라이더 쌍." },
        { "id": "ss-height-slider", "type": "range", "label": "높이", "event": "input(bindSlider)", "writes": "applyHeight → ss.dataset.height + style.height/minHeight", "silentFailRisk": "none", "note": "L634-670." },
        { "id": "ss-height-num", "type": "number", "label": "높이", "event": "input/change(bindSlider)", "writes": "applyHeight", "silentFailRisk": "none", "note": "슬라이더 쌍." },
        { "id": "ss-pady-slider", "type": "range", "label": "상/하 여백", "event": "input(bindSlider)", "writes": "ss.dataset.padY + style.paddingTop/Bottom", "silentFailRisk": "none", "note": "L720-723." },
        { "id": "ss-pady-num", "type": "number", "label": "상/하 여백", "event": "input/change(bindSlider)", "writes": "applyPadY", "silentFailRisk": "none", "note": "슬라이더 쌍." },
        { "id": "ss-tpl-folder", "type": "select", "label": "폴더", "event": "change", "writes": "ss-tpl-folder-new 표시 토글 (input은 직접 쓰지 않음)", "silentFailRisk": "low", "note": "L728-730." },
        { "id": "ss-tpl-folder-new", "type": "text", "label": "새 폴더 이름", "event": "(없음)", "writes": "저장 시 읽기만", "silentFailRisk": "low", "note": "리스너 없음. 저장 버튼에서 value 읽음 — 정상." },
        { "id": "ss-tpl-cat", "type": "select", "label": "카테고리", "event": "(없음)", "writes": "저장 시 읽기만", "silentFailRisk": "low", "note": "저장 버튼에서 value 읽음." },
        { "id": "ss-tpl-name", "type": "text", "label": "컴포넌트 이름", "event": "(없음)", "writes": "저장 시 읽기만", "silentFailRisk": "low", "note": "L733." },
        { "id": "ss-tpl-save-btn", "type": "button", "label": "컴포넌트로 저장", "event": "click", "writes": "window.saveAsTemplate(...)", "silentFailRisk": "low", "note": "L731-743. name 빈값 가드 있음. saveAsTemplate 미정의 시 옵셔널 체이닝으로 조용히 무시되지만 버튼 텍스트는 '저장됨'으로 바뀜 → 거짓 성공 표시 가능." }
