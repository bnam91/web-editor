        { "id": "tbl-merge-headers", "type": "text", "label": "병합", "event": "change", "writes": "window.updateTableBlock(id,{mergedHeaderCols}) + 패널 재렌더", "silentFailRisk": "med", "note": "L614-615. updateTableBlock 미정의(typeof!=='function')면 조용히 return(L605) — 입력해도 아무 변화 없음, 패널 재렌더도 안 됨. 실패 시 console.warn만(L609)." },
