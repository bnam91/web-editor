      "file": "js/props/prop-frame.js",
      "controls": [
        { "id": "ss-banner-preset", "type": "select", "label": "Banner Preset", "event": "change", "writes": "window._applyBannerPreset(ss,key) + 패널 재렌더", "silentFailRisk": "low", "note": "L384-399 banner-preset 변형일 때만 노출. confirm 가드 있음. _applyBannerPreset 미정의 시 옵셔널 체이닝으로 조용히 무시되지만 banner 전용이라 정상." },
        { "id": "ss-banner-swap-btn", "type": "button", "label": "좌우 바꾸기", "event": "click", "writes": "_swapBannerChildren → child.style.left/marginLeft + dataset.offsetX", "silentFailRisk": "low", "note": "L402-404. bannerWidth 0이면 early return(조용). pushHistory/autoSave 호출됨." },
        { "id": "ss-banner-inner-x-slider", "type": "range", "label": "Banner Position X", "event": "input(bindSlider)", "writes": "ss.style.marginLeft", "silentFailRisk": "low", "note": "L408-411. isBannerInner일 때만. dataset 미저장 → marginLeft는 inline style로 직렬화될 것이나 dataset.* 백업 없음." },
        { "id": "ss-banner-inner-x-num", "type": "number", "label": "Banner Position X", "event": "input/change(bindSlider)", "writes": "ss.style.marginLeft", "silentFailRisk": "low", "note": "슬라이더와 양방향 쌍." },
        { "id": "ss-to-stack-btn", "type": "button", "label": "stack (변환)", "event": "click", "writes": "_convertFreeLayoutToStack → DOM 재구성, dataset.fullWidth, gap blocks", "silentFailRisk": "low", "note": "L415-417. freeLayout일 때만 노출. multiRows면 alert 후 중단(가드 OK)." },
        { "id": "ss-pos-x", "type": "number", "label": "Position X", "event": "input", "writes": "ss.dataset.translateX + ss.style.transform", "silentFailRisk": "low", "note": "L429. change 이벤트 없음 → pushHistory 미호출(input만). autoSave는 _applyTransform 내부 호출." },
        { "id": "ss-pos-y", "type": "number", "label": "Position Y", "event": "input", "writes": "ss.dataset.translateY + ss.style.transform", "silentFailRisk": "low", "note": "L430. pushHistory 누락 (undo 체크포인트 없음)." },
        { "id": "ss-align-left", "type": "button", "label": "왼쪽 정렬", "event": "click", "writes": "ss.style.alignItems + dataset.alignItems (+ freeLayout이면 자식 left)", "silentFailRisk": "low", "note": "L493. pushHistory 미호출 — _setAlign 내부엔 scheduleAutoSave만." },
        { "id": "ss-align-hcenter", "type": "button", "label": "가운데 정렬", "event": "click", "writes": "ss.style.alignItems=center", "silentFailRisk": "low", "note": "L494. pushHistory 누락." },
        { "id": "ss-align-right", "type": "button", "label": "오른쪽 정렬", "event": "click", "writes": "ss.style.alignItems=flex-end", "silentFailRisk": "low", "note": "L495. pushHistory 누락." },
        { "id": "ss-align-top", "type": "button", "label": "위 정렬", "event": "click", "writes": "ss.style.justifyContent + dataset.justifyContent", "silentFailRisk": "low", "note": "L497. pushHistory 누락." },
        { "id": "ss-align-vcenter", "type": "button", "label": "세로 가운데", "event": "click", "writes": "ss.style.justifyContent=center", "silentFailRisk": "low", "note": "L498." },
