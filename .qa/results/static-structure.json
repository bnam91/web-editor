      ],
      "syncPairs": [],
      "risks": ["applyRowLayoutDirect stack/grid 분기에 pushHistory/scheduleAutoSave 누락 (flex 분기만 호출). 외부 호출자 책임일 수 있으나 불일치."]
    },
