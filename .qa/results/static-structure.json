        { "id": "row-col-ratio", "type": "text", "label": "비율", "event": "keydown(Enter)/blur", "writes": "col.style.flex/dataset.flex 또는 gridTemplateColumns + dataset.ratioStr", "silentFailRisk": "med", "note": "L254-284. parts.length !== cols/gridColCount 면 조용히 return — 잘못된 비율 입력이 무반응, 사용자에게 피드백 없음. layout!==stack일 때만 노출." },
        { "id": "row-height-slider", "type": "range", "label": "높이", "event": "input", "writes": "rowEl.style.minHeight 또는 gridTemplateRows + dataset.rowHeight", "silentFailRisk": "none", "note": "L169-171. 수동 슬라이더-숫자 동기." },
        { "id": "row-height-number", "type": "number", "label": "높이", "event": "change", "writes": "applyRowHeight", "silentFailRisk": "none", "note": "L170. 슬라이더 쌍." },
        { "id": "row-gap-slider", "type": "range", "label": "gap", "event": "input", "writes": "rowEl.style.gap + dataset.gap", "silentFailRisk": "low", "note": "L248-250. layout!==stack(flex/grid)일 때만 노출 — L235 stack early-return." },
        { "id": "row-gap-number", "type": "number", "label": "gap", "event": "change", "writes": "applyGap", "silentFailRisk": "low", "note": "L249. 슬라이더 쌍. stack이면 미존재(가드됨)." },
