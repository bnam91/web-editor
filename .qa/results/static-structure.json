        { "id": "row-child-r-slider", "type": "range", "label": "radius(card 자식)", "event": "input", "writes": "childBlocks[].dataset.radius + style.borderRadius", "silentFailRisk": "low", "note": "L229-231. allCards일 때만 노출+wire. 정합." },
        { "id": "row-child-r-number", "type": "number", "label": "radius(card 자식)", "event": "change", "writes": "applyChildRadius", "silentFailRisk": "low", "note": "L230. 슬라이더 쌍." }
      ],
      "syncPairs": [
        ["row-height-slider", "row-height-number"],
        ["row-gap-slider", "row-gap-number"],
        ["row-padx-slider", "row-padx-number"],
        ["row-child-h-slider", "row-child-h-number"],
        ["row-child-r-slider", "row-child-r-number"]
      ],
      "risks": [
        "row-col-ratio: parts.length 불일치 시 조용히 return (L258, L276) — 잘못된 비율 입력 시 무반응, 에러 피드백 없음(med).",
        "row-height-number/gap-number/padx-number: input 이벤트 없이 change만 — 타이핑 중 슬라이더 미동기(타이핑 끝나야 반영). 일관성 낮음.",
        "child-h/child-r 핸들러: 비-옵셔널 addEventListener지만 hasChildren/allCards 가드 내에 있어 안전."
      ]
    },
    {
      "block": "row-layout-direct",
