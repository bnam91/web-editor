        { "id": "stb-align-group", "type": "button", "label": "정렬", "wired": true, "writes": "dataset.stepAlign", "silentFail": "none" },
        { "id": "stb-num-bg color", "type": "colorField", "label": "배지 배경색", "wired": true, "writes": "dataset.numBg", "silentFail": "none" },
        { "id": "stb-num-color color", "type": "colorField", "label": "배지 글자색", "wired": true, "writes": "dataset.numColor", "silentFail": "none" },
        { "id": "stb-num-size-slider/number", "type": "range+number", "label": "배지 크기", "wired": true, "writes": "dataset.numSize", "silentFail": "none" },
        { "id": "stb-badge-gap-slider/number", "type": "range+number", "label": "배지 간격", "wired": true, "writes": "dataset.badgeGap", "silentFail": "none" },
        { "id": "stb-start-number", "type": "number", "label": "시작 번호", "wired": true, "event": "input/change", "writes": "dataset.startNumber", "silentFail": "none" },
        { "id": "stb-badge-fmt-select", "type": "select", "label": "배지 형식", "wired": true, "event": "change", "writes": "dataset.badgeFormat", "silentFail": "none" },
        { "id": "stb-title-color color", "type": "colorField", "label": "제목 색", "wired": true, "writes": "dataset.titleColor", "silentFail": "none" },
        { "id": "stb-desc-color color", "type": "colorField", "label": "설명 색", "wired": true, "writes": "dataset.descColor", "silentFail": "none" },
        { "id": "stb-title-size-slider/number", "type": "range+number", "label": "제목 크기", "wired": true, "writes": "dataset.titleSize", "silentFail": "none" },
        { "id": "stb-desc-size-slider/number", "type": "range+number", "label": "설명 크기", "wired": true, "writes": "dataset.descSize", "silentFail": "none" },
        { "id": "stb-gap-slider/number", "type": "range+number", "label": "간격", "wired": true, "writes": "dataset.gap", "silentFail": "none" },
        { "id": "stb-padl/padr-slider/number + chain", "type": "range+number+chain", "label": "L/R 패딩", "wired": true, "writes": "dataset.stepPadL/stepPadR", "silentFail": "low" },
        { "id": "stb-connector", "type": "checkbox", "label": "연결선", "wired": true, "writes": "dataset.connector", "silentFail": "none" },
        { "id": "stb-connector-style-select", "type": "select", "label": "연결선 스타일", "wired": true, "writes": "dataset.connectorStyle", "silentFail": "none" },
        { "id": "stb-title-input / stb-desc-input", "type": "text", "label": "스텝 제목/설명", "wired": true, "event": "input", "writes": "dataset.steps (JSON)", "silentFail": "none" },
        { "id": "stb-del-btn / stb-add-step", "type": "button", "label": "스텝 삭/추가", "wired": true, "writes": "dataset.steps", "silentFail": "none" }
      ],
      "syncPairs": [
        "stb-num-size-slider<->number", "stb-title-size-slider<->number", "stb-desc-size-slider<->number", "stb-gap-slider<->number",
        "stb-badge-gap-slider<->number", "stb-padl-slider<->number", "stb-padr-slider<->number", "stb-padl<->stb-padr (when chain active)"
      ],
      "risks": [
        { "ctrl": "stb-start-number", "level": "med", "line": 333, "why": "On 'input' it writes dataset.startNumber + rerender but does NOT call scheduleAutoSave (only on 'change'). If user types and blurs via panel re-render before 'change' fires (e.g. selecting another block), the value persists in dataset but autoSave path relies on the later 'change' — generally OK since MutationObserver autosave watches dataset. Marginal." },
        { "ctrl": "stepPadX legacy migration", "level": "low", "line": 46, "why": "stepPadL/R read falls back to legacy stepPadX, but writes only stepPadL/stepPadR — old stepPadX stays in dataset stale (never deleted). Harmless but could confuse serialization/diff." },
        { "ctrl": "stb-padl/padr number 'input' vs 'change'", "level": "low", "line": 313, "why": "slider uses 'input' live; number uses 'change' only — typing in number box doesn't live-preview until blur. Minor UX, not data loss." }
      ]
    },
