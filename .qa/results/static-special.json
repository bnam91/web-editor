        { "id": "bn2-swap", "type": "button", "label": "좌우 바꾸기", "wired": true, "writes": "dataset.textX/imgX", "silentFail": "none" },
        { "id": "bn2-align-group [data-align]", "type": "button", "label": "텍스트 정렬", "wired": true, "writes": "dataset.align", "silentFail": "none" }
      ],
      "syncPairs": [
