      "controls": [
        { "id": "grb-h-slider/number", "type": "range+number", "label": "높이", "wired": true, "event": "input/change", "writes": "dataset.chartHeight", "silentFail": "none" },
        { "id": "grb-label-slider/number", "type": "range+number", "label": "라벨", "wired": true, "event": "input/change", "writes": "dataset.labelSize", "silentFail": "none" },
        { "id": "grb-label color", "type": "colorField", "label": "라벨 색상", "wired": true, "event": "apply/commit", "writes": "dataset.labelColor", "silentFail": "none" },
        { "id": "grb-vlabel color", "type": "colorField", "label": "값 색상", "wired": true, "writes": "dataset.vlabelColor", "silentFail": "none" },
        { "id": "grb-xlabel color", "type": "colorField", "label": "카테고리 색상", "wired": true, "writes": "dataset.xlabelColor", "silentFail": "none" },
        { "id": "grb-show-vlabel", "type": "checkbox", "label": "값 표시", "wired": true, "event": "change", "writes": "dataset.showVLabel", "silentFail": "none" },
        { "id": "grb-show-xlabel", "type": "checkbox", "label": "카테고리 표시", "wired": true, "event": "change", "writes": "dataset.showXLabel", "silentFail": "none" },
        { "id": "grb-stroke-slider/number", "type": "range+number", "label": "선 두께 (line)", "wired": true, "writes": "dataset.strokeWidth", "silentFail": "none" },
        { "id": "grb-point-slider/number", "type": "range+number", "label": "점 크기 (line)", "wired": true, "writes": "dataset.pointRadius", "silentFail": "none" },
        { "id": "grb-padx-slider/number", "type": "range+number", "label": "좌우 패딩 (line/bar-h)", "wired": true, "writes": "dataset.padX", "silentFail": "low", "note": "id duplicated in both line & bar-h conditional sections but only one renders at a time (mutually exclusive chartType) — no real DOM collision" },
        { "id": "grb-fillarea-toggle", "type": "checkbox", "label": "면 채우기 (line)", "wired": true, "writes": "dataset.fillArea", "silentFail": "none" },
        { "id": "grb-fill color", "type": "colorField", "label": "면 색상 (line)", "wired": true, "writes": "dataset.fillColor", "silentFail": "none" },
        { "id": "grb-fillalpha-slider/number", "type": "range+number", "label": "투명도 (line)", "wired": true, "writes": "dataset.fillAlpha", "silentFail": "none" },
        { "id": "grb-bar-thickness-slider/number", "type": "range+number", "label": "두께 (bar-h)", "wired": true, "writes": "dataset.barThickness", "silentFail": "none" },
        { "id": "grb-item-gap-slider/number", "type": "range+number", "label": "항목 간격 (bar-h)", "wired": true, "writes": "dataset.itemGap", "silentFail": "none" },
        { "id": "grb-pct-size-slider/number", "type": "range+number", "label": "숫자 크기 (bar-h)", "wired": true, "writes": "dataset.pctSize", "silentFail": "none" },
        { "id": "grb-bar color", "type": "colorField", "label": "바/선 색상", "wired": true, "writes": "dataset.barColor OR dataset.lineColor (chartType dependent)", "silentFail": "none" },
        { "id": "grb-type-v/h/line", "type": "button", "label": "차트 타입", "wired": true, "event": "click", "writes": "dataset.chartType", "silentFail": "none" },
        { "id": "grb-preset-*", "type": "button", "label": "프리셋", "wired": true, "event": "click", "writes": "dataset.preset", "silentFail": "none" },
        { "id": "grb-data-list inputs", "type": "text+number", "label": "데이터 라벨/값", "wired": true, "event": "input", "writes": "dataset.items (JSON)", "silentFail": "none" },
        { "id": "grb-data-del-btn / grb-add-item", "type": "button", "label": "데이터 삭/추가", "wired": true, "writes": "dataset.items", "silentFail": "none" }
      ],
      "syncPairs": [
        "grb-h-slider<->grb-h-number", "grb-label-slider<->grb-label-number", "grb-stroke-slider<->grb-stroke-number",
        "grb-point-slider<->grb-point-number", "grb-padx-slider<->grb-padx-number", "grb-fillalpha-slider<->grb-fillalpha-number",
        "grb-bar-thickness-slider<->grb-bar-thickness-number", "grb-item-gap-slider<->grb-item-gap-number", "grb-pct-size-slider<->grb-pct-size-number"
      ],
      "risks": [
        { "ctrl": "grb-bar color", "level": "low", "line": 321, "why": "color applied to barColor for bar charts but lineColor for line charts; the label HTML says '선 색상'/'바 색상' from chartType but the persisted key differs (barColor vs lineColor). When toggling chartType, a previously-set lineColor won't carry to barColor and vice versa — perceived 'reset'. Not a hard fail but easy to misread as data loss." }
      ]
    },
    {
      "block": "comparison",
      "panelFn": "showComparisonProperties",
      "file": "js/props/prop-comparison.js",
      "controls": [
        { "id": "cmp-feat-group [data-feat]", "type": "button", "label": "강조 칼럼", "wired": true, "event": "click", "writes": "dataset.featured", "silentFail": "none" },
        { "id": "cmp-col-add", "type": "button", "label": "+ 칼럼 추가", "wired": true, "writes": "cols (setComparisonCols) + dataset.featured", "silentFail": "none" },
        { "id": "cmp-col-del", "type": "button", "label": "칼럼 삭제", "wired": true, "writes": "cols", "silentFail": "none" },
        { "id": "cmp-scale/-num", "type": "range+number", "label": "강조 크기", "wired": true, "writes": "dataset.featScale", "silentFail": "none", "note": "separate float handler" },
        { "id": "cmp-ovl/-num", "type": "range+number", "label": "겹침", "wired": true, "writes": "dataset.overlap", "silentFail": "none" },
        { "id": "cmp-rad/-num", "type": "range+number", "label": "반경", "wired": true, "writes": "dataset.radius", "silentFail": "none" },
        { "id": "cmp-padx/-num", "type": "range+number", "label": "좌우 패딩", "wired": true, "writes": "dataset.padX", "silentFail": "none" },
        { "id": "cmp-pady/-num", "type": "range+number", "label": "상하 패딩", "wired": true, "writes": "dataset.padY", "silentFail": "none" },
        { "id": "cmp-tfont/-num", "type": "range+number", "label": "제목 크기", "wired": true, "writes": "dataset.titleFont", "silentFail": "none" },
        { "id": "cmp-rfont/-num", "type": "range+number", "label": "내용 크기", "wired": true, "writes": "dataset.rowFont", "silentFail": "none" },
        { "id": "cmp-rowh/-num", "type": "range+number", "label": "행 높이", "wired": true, "writes": "dataset.rowH", "silentFail": "none" },
        { "id": "cmp-rowgap/-num", "type": "range+number", "label": "행 간격", "wired": true, "writes": "dataset.rowGap", "silentFail": "none" },
        { "id": "cmp-col-title", "type": "textarea", "label": "칼럼 제목", "wired": true, "event": "input/change", "writes": "cols[i].title", "silentFail": "none" },
        { "id": "cmp-c{i}Bg color", "type": "colorField+gradient", "label": "배경", "wired": true, "writes": "cols[i].bg", "silentFail": "none" },
        { "id": "cmp-c{i}Text color", "type": "colorField", "label": "텍스트", "wired": true, "writes": "cols[i].text", "silentFail": "none" },
        { "id": "cmp-row-input", "type": "text", "label": "행 내용", "wired": true, "event": "input/change", "writes": "cols[i].rows[j]", "silentFail": "none" },
        { "id": "cmp-row-del / cmp-row-add", "type": "button", "label": "행 삭/추가", "wired": true, "writes": "cols[i].rows", "silentFail": "none" }
      ],
      "syncPairs": [
        "cmp-scale<->cmp-scale-num", "cmp-ovl<->cmp-ovl-num", "cmp-rad<->cmp-rad-num", "cmp-padx<->cmp-padx-num",
        "cmp-pady<->cmp-pady-num", "cmp-tfont<->cmp-tfont-num", "cmp-rfont<->cmp-rfont-num", "cmp-rowh<->cmp-rowh-num", "cmp-rowgap<->cmp-rowgap-num",
        "cmp-c{i}Bg gradient <-> canvas gradient-line (via gradient-line:change, source-guarded)"
      ],
      "risks": [
        { "ctrl": "cmp-* pair() sliders", "level": "low", "line": 114, "why": "pair() binds both slider AND number to 'input' with parseInt; commit() only on 'change'. Works, but number field uses parseInt (no float) — fine for these int props. No silent fail." },
        { "ctrl": "gradient-line:change handler", "level": "low", "line": 181, "why": "uses window.getComparisonCols/getComparisonFeaturedIdx (global) but file imports module versions; if globals not exposed, swatch sync no-ops. Cosmetic only (swatch preview), data path unaffected." }
      ]
    },
    {
