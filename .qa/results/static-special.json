        { "id": "bn2-line-{i}-col color", "type": "colorField", "label": "색", "wired": true, "writes": "_bn2Lines[i].color", "silentFail": "none" },
        { "id": "line remove [data-line-remove]", "type": "button", "label": "줄 삭제", "wired": true, "writes": "_bn2Lines", "silentFail": "none" },
        { "id": "bn2-line-add", "type": "button", "label": "줄 추가", "wired": true, "writes": "_bn2Lines", "silentFail": "none" },
        { "id": "bn2-img-upload / bn2-img-clear", "type": "button", "label": "이미지 추가/제거", "wired": true, "writes": "dataset.imgSrc", "silentFail": "none" },
