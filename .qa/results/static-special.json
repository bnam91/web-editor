        { "id": "bn2-radius/-num", "type": "range+number", "label": "반경", "wired": true, "writes": "dataset.radius", "silentFail": "none" },
        { "id": "line kind select [data-line-kind]", "type": "select", "label": "줄 종류(Label/Title/Sub)", "wired": true, "writes": "_bn2Lines[i].kind", "silentFail": "none" },
        { "id": "line text [data-line-text]", "type": "textarea", "label": "줄 텍스트", "wired": true, "event": "input/change", "writes": "_bn2Lines[i].text", "silentFail": "none" },
