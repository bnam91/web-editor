{
  "name": "sangpe-editor",
  "version": "1.0.0",
  "description": "상페마법사 — 상세페이지 제작용 에디터",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging --remote-debugging-port=9334 --remote-allow-origins=* admin",
    "dev:step2": "electron . --enable-logging --remote-debugging-port=9335 --remote-allow-origins=* admin",
    "dev:planning": "electron . --enable-logging --remote-debugging-port=9336 --remote-allow-origins=* admin",
    "dev:ui-polish": "electron . --enable-logging --remote-debugging-port=9337 --remote-allow-origins=* admin",
    "dev:design-token": "electron . --enable-logging --remote-debugging-port=9338 --remote-allow-origins=* admin",
    "dev:template-tag": "electron . --enable-logging --remote-debugging-port=9339 --remote-allow-origins=* admin",
    "build:mac": "electron-builder --mac --dir",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "figma": "bun run figma-plugin/socket.js"
  },
  "build": {
    "appId": "com.goyamkt.sangpe-editor",
    "productName": "상페마법사",
    "publish": {
      "provider": "github",
      "owner": "bnam91",
      "repo": "web-editor"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "**/*",
      "!.git",
      "!dist",
      "!*.md"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bnam91/web-editor.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/bnam91/web-editor/issues"
  },
  "homepage": "https://github.com/bnam91/web-editor#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "mongodb": "^7.1.0",
    "ws": "^8.20.0"
  }
}